{
    "name": "BriefAI",
    "short_name": "BriefAI",
    "description": "AI-powered CEO Morning Briefing Platform for Indian executives",
    "id": "/?source=pwa",
    "start_url": "/?source=pwa",
    "scope": "/",
    "display": "standalone",
    "display_override": [
        "window-controls-overlay",
        "standalone"
    ],
    "orientation": "portrait-primary",
    "background_color": "#000000",
    "theme_color": "#000000",
    "lang": "en-IN",
    "dir": "ltr",
    "categories": [
        "finance",
        "news",
        "productivity",
        "business"
    ],
    "icons": [
        {
            "src": "/logo.svg",
            "sizes": "any",
            "type": "image/svg+xml",
            "purpose": "any"
        },
        {
            "src": "/logo.svg",
            "sizes": "any",
            "type": "image/svg+xml",
            "purpose": "maskable"
        },
        {
            "src": "/logo.png",
            "sizes": "192x192",
            "type": "image/png",
            "purpose": "any"
        },
        {
            "src": "/logo2.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "any"
        }
    ],
    "screenshots": [
        {
            "src": "/screenshot1.png",
            "sizes": "1080x2400",
            "type": "image/png",
            "form_factor": "narrow",
            "label": "AI-powered Index Comparison"
        },
        {
            "src": "/screenshot2.png",
            "sizes": "1080x2400",
            "type": "image/png",
            "form_factor": "narrow",
            "label": "Intelligence Overview"
        },
        {
            "src": "/screenshot3.png",
            "sizes": "1080x2400",
            "type": "image/png",
            "form_factor": "narrow",
            "label": "Executive Briefing"
        }
    ],
    "shortcuts": [
        {
            "name": "Today's Brief",
            "url": "/?source=shortcut",
            "description": "Get your daily morning intelligence",
            "icons": [
                {
                    "src": "/logo.svg",
                    "sizes": "any"
                }
            ]
        }
    ],
    "prefer_related_applications": false,
    "related_applications": [],
    "file_handlers": [
        {
            "action": "/?file=%s",
            "accept": {
                "text/plain": [
                    ".txt"
                ],
                "application/json": [
                    ".json"
                ]
            }
        }
    ],
    "launch_handler": {
        "client_mode": "focus-existing"
    },
    "protocol_handlers": [
        {
            "protocol": "web+briefai",
            "url": "/?url=%s"
        }
    ],
    "share_target": {
        "action": "/?share=true",
        "method": "GET",
        "enctype": "application/x-www-form-urlencoded",
        "params": {
            "title": "title",
            "text": "text",
            "url": "url"
        }
    },
    "iarc_rating_id": "",
    "widgets": [],
    "edge_side_panel": {
        "preferred_width": 376
    },
    "note_taking": {
        "new_note_url": "/?action=new-note"
    },
    "scope_extensions": []
}